---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Moleculytics – AI Education for Pharma & Life Science Graduates">
  <!-- ─── HERO SECTION ─── -->
  <section class="hero">
    <div class="container hero-wrapper">
      <div class="hero-content">
        <div class="hero-badge">🧬 AI × Pharma Education</div>
        <h1 class="hero-title">Integrating AI in Pharma.<br /><span>Build Practical Skills.</span></h1>
        <p class="hero-desc">
          Learn Python, Cheminformatics, and Machine Learning designed specifically for life scientists in India. No coding background required.
        </p>
        <div class="hero-actions">
          <a href="https://forms.gle/ZGMrf2sWeRbbn6Mg8" target="_blank" rel="noopener" class="btn-primary">Register Interest</a>
          <a href="/lead_magnet" class="btn-secondary">Download Free Guide</a>
        </div>
      </div>
      <div class="hero-visual">
        <div class="mockup-card">
          <div class="mockup-header">
            <span class="dot r"></span>
            <span class="dot y"></span>
            <span class="dot g"></span>
            <span class="mockup-title">qsar_model.py</span>
          </div>
          <div class="mockup-content">
            <p><span class="keyword">import</span> rdkit</p>
            <p><span class="keyword">from</span> rdkit <span class="keyword">import</span> Chem</p>
            <p><span class="keyword">from</span> sklearn.ensemble <span class="keyword">import</span> RandomForestRegressor</p>
            <p>&nbsp;</p>
            <p><span class="comment"># Define a molecule using SMILES representation</span></p>
            <p>smiles = <span class="string">"CC(=O)OC1=CC=CC=C1C(=O)O"</span> <span class="comment"># Aspirin</span></p>
            <p>mol = Chem.MolFromSmiles(smiles)</p>
            <p>&nbsp;</p>
            <p><span class="comment"># Predict drug absorption (ADMET) using AI</span></p>
            <p>predicted_solubility = model.predict(mol)</p>
            <p><span class="call">print</span>(<span class="string">f"Solubility: &#123;predicted_solubility&#125;"</span>)</p>
            <p>&nbsp;</p>
            <p><span class="comment">&gt;&gt;&gt; Solubility predicted in 0.04 seconds!</span></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── STATISTICS BAR ─── -->
  <section class="stats-bar">
    <div class="container stats-grid">
      <div class="stat-item">
        <h3>$9B</h3>
        <p>AI Drug Discovery Market by 2030</p>
      </div>
      <div class="stat-item">
        <h3>~50%</h3>
        <p>Reduction in Target Identification Time</p>
      </div>
      <div class="stat-item">
        <h3>3,000+</h3>
        <p>Pharma Companies Building AI Teams in India</p>
      </div>
    </div>
  </section>

  <!-- ─── CORE VALUES / GAP & SHORTCUT ─── -->
  <section id="about" class="section-padding">
    <div class="container">
      <div class="section-title-wrap">
        <span class="section-label">The Opportunity</span>
        <h2 class="section-title">Bridging the Gap Between Biology and Computer Science</h2>
      </div>

      <div class="values-grid">
        <div class="value-card gap">
          <h3><span>The Talent Gap</span>Life Scientists vs. Engineers</h3>
          <p>
            Most AI courses are written by computer scientists for other computer scientists. They are filled with complex math equations and general software concepts that have nothing to do with drug molecules, assay results, or clinical trials. Meanwhile, life scientists have the biology domain expertise but feel locked out by the coding syntax.
          </p>
        </div>
        <div class="value-card shortcut">
          <h3><span>AI-Assisted Workflows</span>Augmenting Scientific Research</h3>
          <p>
            With modern AI coding assistants, you can streamline writing code for data analysis. Instead of starting from scratch, you can use these tools to scaffold pipelines, allowing you to focus on the biological and chemical concepts. Moleculytics teaches you how to guide and validate these models successfully.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── WORKSHOPS SECTION ─── -->
  <section id="workshops" class="section-padding" style="background: rgba(26, 43, 107, 0.1); border-top: 1px solid var(--card-border); border-bottom: 1px solid var(--card-border);">
    <div class="container">
      <div class="section-title-wrap">
        <span class="section-label">Live Learning</span>
        <h2 class="section-title">Upcoming AI × Pharma Workshops</h2>
      </div>

      <div class="workshop-grid">
        <!-- Workshop 1 -->
        <div class="workshop-card w1">
          <div class="workshop-header">
            <span class="workshop-level">Level 1 · Essential</span>
            <h3>Python Basics for Life Sciences</h3>
            <p class="workshop-desc">The absolute starting point. Learn the foundations of scientific Python, data structures, and how to clean molecular datasets.</p>
          </div>
          <div>
            <ul class="workshop-syllabus">
              <li>Variables &amp; Lists in Python</li>
              <li>Intro to Pandas (handling CSVs)</li>
              <li>Cleaning clinical and chemical data</li>
              <li>Generating data charts in Seaborn</li>
            </ul>
            <a href="https://forms.gle/ZGMrf2sWeRbbn6Mg8" target="_blank" rel="noopener" class="btn-card">Register Interest</a>
          </div>
        </div>

        <!-- Workshop 2 -->
        <div class="workshop-card w2">
          <div class="workshop-header">
            <span class="workshop-level">Level 2 · Intermediate</span>
            <h3>Cheminformatics &amp; Molecular Data</h3>
            <p class="workshop-desc">How to represent chemistry as code. Learn to use RDKit, represent chemical structures in Python, and calculate molecular descriptors.</p>
          </div>
          <div>
            <ul class="workshop-syllabus">
              <li>SMILES structures to 2D molecules</li>
              <li>Calculating molecular weight &amp; LogP</li>
              <li>Chemical similarity searches</li>
              <li>Setting up local RDKit pipelines</li>
            </ul>
            <a href="https://forms.gle/ZGMrf2sWeRbbn6Mg8" target="_blank" rel="noopener" class="btn-card">Register Interest</a>
          </div>
        </div>

        <!-- Workshop 3 -->
        <div class="workshop-card w3">
          <div class="workshop-header">
            <span class="workshop-level">Level 3 · Advanced</span>
            <h3>Machine Learning for Drug Discovery</h3>
            <p class="workshop-desc">Build QSAR and predictive models. Train machine learning algorithms to predict ADMET properties and molecule toxicity automatically.</p>
          </div>
          <div>
            <ul class="workshop-syllabus">
              <li>Random Forests for activity prediction</li>
              <li>ADMET property predictions</li>
              <li>Evaluating ML model accuracy</li>
              <li>Busting Black-Box ML algorithms</li>
            </ul>
            <a href="https://forms.gle/ZGMrf2sWeRbbn6Mg8" target="_blank" rel="noopener" class="btn-card">Register Interest</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── ROADMAP GUIDE PROMO ─── -->
  <section id="roadmap" class="section-padding">
    <div class="container">
      <div class="roadmap-promo">
        <div class="roadmap-promo-wrapper">
          <div>
            <span class="section-label" style="color: var(--teal);">Free Resource</span>
            <h2 class="roadmap-promo-title">The AI Roadmap for Pharma &amp; Life Science Graduates</h2>
            <p class="roadmap-promo-desc">
              We wrote a short, practical 5-page guide to help you orient your learning path. Discover which skills matter most in the industry, myths to avoid, and how AI tools act as your shortcut.
            </p>
            <ul class="roadmap-promo-bullets">
              <li>Why AI matters in India</li>
              <li>5 Myths Busted</li>
              <li>Priority Skills Map</li>
              <li>AI Coding Shortcuts</li>
            </ul>
            <a href="/lead_magnet" class="btn-primary" style="display:inline-block;">Read Free Roadmap</a>
          </div>
          <div class="book-mockup">
            <div class="book-card">
              <img src="/Moleculytics My brand.png" alt="Moleculytics" class="book-logo" />
              <div class="book-title">The AI Roadmap<br />for<br /><span>Pharma Grads</span></div>
              <div class="book-footer">MOLECULYTICS · 2026</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── FINAL CTA BLOCK ─── -->
  <section class="container section-padding" style="padding-top: 0;">
    <div class="cta-block">
      <div class="cta-content">
        <h2 class="cta-title-main">Join Our Practical AI × Pharma Curriculum</h2>
        <p class="cta-text">
          Tell us about your background, career goals, and which topics interest you most. We use this information to design custom, interactive live workshops that bridge the gap.
        </p>
        <a href="https://forms.gle/ZGMrf2sWeRbbn6Mg8" target="_blank" rel="noopener" class="btn-primary" style="font-size: 16px; padding: 16px 36px;">Fill Out the 2-Minute Interest Form</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .section-padding {
    padding: 100px 0;
  }

  /* ─── HERO SECTION ─── */
  .hero {
    position: relative;
    padding-top: 180px;
    padding-bottom: 120px;
    overflow: hidden;
  }

  /* background glowing lights */
  .hero::before {
    content: '';
    position: absolute;
    top: -200px;
    right: -200px;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(0, 188, 212, 0.15) 0%, transparent 70%);
    z-index: -1;
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: -100px;
    left: -200px;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 77, 184, 0.1) 0%, transparent 70%);
    z-index: -1;
  }

  .hero-wrapper {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    align-items: center;
    gap: 60px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(0, 188, 212, 0.1);
    border: 1px solid rgba(0, 188, 212, 0.3);
    padding: 6px 16px;
    border-radius: 100px;
    font-size: 11px;
    font-weight: 700;
    color: var(--teal);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 24px;
  }

  .hero-title {
    font-size: 58px;
    line-height: 1.1;
    margin-bottom: 20px;
    letter-spacing: -1px;
  }

  .hero-title span {
    background: linear-gradient(90deg, var(--teal), var(--pink));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-desc {
    font-size: 18px;
    color: var(--gray-text);
    max-width: 600px;
    margin-bottom: 40px;
  }

  .hero-actions {
    display: flex;
    gap: 20px;
    align-items: center;
  }

  /* PREMIUM BUTTONS */
  .btn-primary {
    background: linear-gradient(135deg, var(--teal), var(--teal-dark));
    color: var(--navy-dark);
    padding: 14px 28px;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 700;
    box-shadow: 0 4px 20px rgba(0, 188, 212, 0.3);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0, 188, 212, 0.5);
  }

  .btn-secondary {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: var(--white);
    padding: 14px 28px;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 600;
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.3);
    transform: translateY(-2px);
  }

  /* Hero Visual Card Mockup */
  .hero-visual {
    position: relative;
  }

  .mockup-card {
    background: linear-gradient(135deg, rgba(26, 43, 107, 0.3) 0%, rgba(13, 27, 75, 0.5) 100%);
    border: 1px solid var(--card-border);
    border-radius: 24px;
    padding: 30px;
    backdrop-filter: blur(10px);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
    position: relative;
  }

  .mockup-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding-bottom: 16px;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .dot.r { background: #ff5f56; }
  .dot.y { background: #ffbd2e; }
  .dot.g { background: #27c93f; }

  .mockup-title {
    font-size: 14px;
    color: var(--gray-text);
    font-family: monospace;
    margin-left: 10px;
  }

  .mockup-content {
    font-family: monospace;
    font-size: 12px;
    color: #9cdcfe;
  }

  .mockup-content span.keyword { color: #c586c0; }
  .mockup-content span.string { color: #ce9178; }
  .mockup-content span.comment { color: #6a9955; }
  .mockup-content span.call { color: #dcdcaa; }

  /* ─── STATS SECTION ─── */
  .stats-bar {
    border-top: 1px solid var(--card-border);
    border-bottom: 1px solid var(--card-border);
    background: rgba(26, 43, 107, 0.15);
    padding: 40px 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
    text-align: center;
  }

  .stat-item h3 {
    font-size: 42px;
    font-weight: 800;
    color: var(--teal);
    margin-bottom: 4px;
  }

  .stat-item p {
    font-size: 13px;
    color: var(--gray-text);
    letter-spacing: 1px;
    text-transform: uppercase;
    font-weight: 500;
  }

  /* ─── CORE VALUES (THE OPP & SHORTCUT) ─── */
  .values-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
    margin-top: 40px;
  }

  .value-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 20px;
    padding: 40px;
    position: relative;
    overflow: hidden;
  }

  .value-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
  }

  .value-card.gap::before {
    background: var(--pink);
  }

  .value-card.shortcut::before {
    background: var(--teal);
  }

  .value-card h3 {
    font-size: 24px;
    margin-bottom: 16px;
  }

  .value-card h3 span {
    display: block;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    margin-bottom: 8px;
  }

  .value-card.gap h3 span { color: var(--pink); }
  .value-card.shortcut h3 span { color: var(--teal); }

  .value-card p {
    color: var(--gray-text);
    font-size: 15px;
    line-height: 1.7;
  }

  /* ─── WORKSHOPS SECTION ─── */
  .section-title-wrap {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 60px;
  }

  .section-label {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 12px;
  }

  .section-title {
    font-size: 38px;
    line-height: 1.2;
  }

  .workshop-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .workshop-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 16px;
    padding: 30px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: all 0.3s ease;
  }

  .workshop-card:hover {
    border-color: rgba(0, 188, 212, 0.3);
    transform: translateY(-5px);
    background: rgba(255, 255, 255, 0.05);
  }

  .workshop-header {
    margin-bottom: 24px;
  }

  .workshop-level {
    display: inline-block;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 100px;
    margin-bottom: 16px;
  }

  .workshop-card.w1 .workshop-level {
    background: rgba(0, 188, 212, 0.1);
    color: var(--teal);
    border: 1px solid rgba(0, 188, 212, 0.2);
  }

  .workshop-card.w2 .workshop-level {
    background: rgba(255, 77, 184, 0.1);
    color: var(--pink);
    border: 1px solid rgba(255, 77, 184, 0.2);
  }

  .workshop-card.w3 .workshop-level {
    background: rgba(76, 175, 80, 0.1);
    color: #81c784;
    border: 1px solid rgba(76, 175, 80, 0.2);
  }

  .workshop-card h3 {
    font-size: 20px;
    margin-bottom: 12px;
    line-height: 1.3;
  }

  .workshop-desc {
    font-size: 13.5px;
    color: var(--gray-text);
    line-height: 1.6;
    margin-bottom: 20px;
  }

  .workshop-syllabus {
    list-style: none;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 16px;
    margin-bottom: 30px;
  }

  .workshop-syllabus li {
    font-size: 13px;
    color: var(--body-text);
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
  }

  .workshop-syllabus li::before {
    content: '→';
    color: var(--teal);
    font-weight: 700;
  }

  .btn-card {
    display: block;
    width: 100%;
    text-align: center;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--white);
    padding: 10px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
  }

  .workshop-card:hover .btn-card {
    background: var(--teal);
    color: var(--navy-dark);
    border-color: var(--teal);
  }

  /* ─── ROADMAP DOWNLOAD CALLOUT ─── */
  .roadmap-promo {
    background: linear-gradient(135deg, rgba(26, 43, 107, 0.4) 0%, rgba(13, 27, 75, 0.7) 100%);
    border: 1px solid var(--card-border);
    border-radius: 24px;
    padding: 60px;
    position: relative;
    overflow: hidden;
  }

  /* background glowing light */
  .roadmap-promo::before {
    content: '';
    position: absolute;
    top: -150px;
    right: -150px;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(0, 188, 212, 0.2) 0%, transparent 60%);
    border-radius: 50%;
  }

  .roadmap-promo-wrapper {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    align-items: center;
    gap: 60px;
    position: relative;
    z-index: 2;
  }

  .roadmap-promo-title {
    font-size: 34px;
    line-height: 1.2;
    margin-bottom: 16px;
  }

  .roadmap-promo-desc {
    font-size: 15px;
    color: var(--gray-text);
    line-height: 1.7;
    margin-bottom: 28px;
  }

  .roadmap-promo-bullets {
    list-style: none;
    margin-bottom: 36px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px 24px;
  }

  .roadmap-promo-bullets li {
    font-size: 13.5px;
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--body-text);
  }

  .roadmap-promo-bullets li::before {
    content: '✓';
    color: var(--teal);
    font-weight: 800;
  }

  /* Mockup graphic of the book */
  .book-mockup {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .book-card {
    width: 260px;
    height: 360px;
    background: linear-gradient(145deg, var(--navy-dark) 0%, var(--navy) 50%, var(--navy-light) 100%);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 12px;
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4);
    padding: 30px 24px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
  }

  .book-card::after {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    width: 15px;
    height: 100%;
    background: linear-gradient(to right, rgba(0, 0, 0, 0.2) 0%, rgba(255, 255, 255, 0.05) 100%);
    border-radius: 12px 0 0 12px;
  }

  .book-logo {
    height: 48px;
    align-self: center;
  }

  .book-title {
    font-size: 20px;
    font-weight: 800;
    color: var(--white);
    line-height: 1.2;
    text-align: center;
  }

  .book-title span {
    background: linear-gradient(90deg, var(--teal), var(--pink));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .book-footer {
    font-size: 10px;
    color: var(--teal);
    text-align: center;
    font-weight: 700;
    letter-spacing: 1px;
  }

  /* ─── FINAL CTA / CAPTURE ─── */
  .cta-block {
    background: linear-gradient(135deg, #091334 0%, #15245C 100%);
    border: 1px solid var(--card-border);
    border-radius: 24px;
    padding: 80px 40px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .cta-block::before {
    content: '';
    position: absolute;
    bottom: -150px;
    left: -150px;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(255, 77, 184, 0.15) 0%, transparent 60%);
    border-radius: 50%;
  }

  .cta-content {
    max-width: 650px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .cta-title-main {
    font-size: 42px;
    margin-bottom: 20px;
    line-height: 1.2;
  }

  .cta-text {
    font-size: 16px;
    color: var(--gray-text);
    margin-bottom: 40px;
  }

  /* ─── RESPONSIVE STYLES ─── */
  @media (max-width: 1024px) {
    .hero-title {
      font-size: 48px;
    }
    .hero-wrapper {
      gap: 40px;
    }
    .workshop-grid {
      grid-template-columns: 1fr;
      max-width: 500px;
      margin: 0 auto;
    }
  }

  @media (max-width: 768px) {
    .section-padding {
      padding: 60px 0;
    }
    .hero-wrapper {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hero-badge {
      margin: 0 auto 24px;
    }
    .hero-desc {
      margin: 0 auto 40px;
    }
    .hero-actions {
      justify-content: center;
    }
