<style>
  /* ─── RESET & BASE ─── */
  *,
  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --navy: #1A2B6B;
    --teal: #0097A7;
    --teal2: #00BCD4;
    --pink: #E91E8C;
    --pink2: #FF4DB8;
    --green: #4CAF50;
    --light: #F0FAFC;
    --white: #FFFFFF;
    --gray: #64748B;
    --gray-lt: #F1F5F9;
    --dark: #0D1B4B;
  }

  body {
    font-family: 'Inter', sans-serif;
    background: #e8edf5 !important;
    color: #1e293b !important;
  }

  .page {
    width: 794px;
    height: 1123px;
    background: white;
    margin: 32px auto;
    position: relative;
    overflow: hidden;
    page-break-after: always;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.15);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  /* ══════════════════════════════════════
     PAGE 1 — COVER
  ══════════════════════════════════════ */
  .cover {
    height: 100%;
    background: linear-gradient(145deg, var(--dark) 0%, var(--navy) 50%, #1e3a8a 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    padding: 52px 60px 48px;
    position: relative;
  }

  /* decorative circles */
  .cover::before {
    content: '';
    position: absolute;
    top: -120px;
    right: -120px;
    width: 420px;
    height: 420px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(0, 188, 212, 0.18) 0%, transparent 70%);
  }

  .cover::after {
    content: '';
    position: absolute;
    bottom: -80px;
    left: -80px;
    width: 360px;
    height: 360px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(233, 30, 140, 0.15) 0%, transparent 70%);
  }

  .cover-top {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    z-index: 2;
  }

  .cover-logo {
    height: 140px;
    margin-bottom: 20px;
  }

  .cover-badge {
    background: rgba(0, 188, 212, 0.2);
    border: 1px solid rgba(0, 188, 212, 0.5);
    color: var(--teal2);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    padding: 6px 20px;
    border-radius: 100px;
    margin-bottom: 36px;
  }

  .cover-title {
    font-family: 'Outfit', sans-serif;
    font-size: 52px;
    font-weight: 800;
    color: white;
    text-align: center;
    line-height: 1.12;
    margin-bottom: 10px;
  }

  .cover-title span {
    background: linear-gradient(90deg, var(--teal2), var(--pink2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .cover-subtitle {
    font-size: 18px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.72);
    text-align: center;
    max-width: 520px;
    line-height: 1.6;
    margin-bottom: 48px;
  }

  /* hero visual */
  .cover-hero {
    display: flex;
    gap: 20px;
    margin-bottom: 48px;
    z-index: 2;
  }

  .hero-pill {
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 16px;
    padding: 18px 24px;
    display: flex;
    align-items: center;
    gap: 12px;
    backdrop-filter: blur(10px);
  }

  .hero-pill-icon {
    font-size: 28px;
  }

  .hero-pill-text strong {
    display: block;
    color: white;
    font-size: 14px;
    font-weight: 700;
  }

  .hero-pill-text span {
    color: rgba(255, 255, 255, 0.55);
    font-size: 12px;
  }

  /* what's inside */
  .cover-inside {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 20px;
    padding: 28px 36px;
    width: 100%;
    z-index: 2;
  }

  .cover-inside h3 {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--teal2);
    margin-bottom: 18px;
  }

  .inside-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .inside-item {
    display: flex;
    align-items: center;
    gap: 10px;
    color: rgba(255, 255, 255, 0.85);
    font-size: 13.5px;
    font-weight: 500;
  }

  .inside-item::before {
    content: '✓';
    width: 20px;
    height: 20px;
    background: linear-gradient(135deg, var(--teal), var(--teal2));
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    font-weight: 800;
    color: white;
    flex-shrink: 0;
  }

  .cover-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    z-index: 2;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 24px;
  }

  .cover-footer span {
    color: rgba(255, 255, 255, 0.45);
    font-size: 12px;
  }

  .cover-footer .brand {
    color: var(--teal2);
    font-weight: 700;
    font-size: 13px;
  }

  /* ══════════════════════════════════════
     INNER PAGE SHARED STYLES
  ══════════════════════════════════════ */
  .inner-page {
    height: 100%;
    padding: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .page-header {
    background: linear-gradient(135deg, var(--navy) 0%, #1e3a8a 100%);
    padding: 28px 52px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .page-header-left {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .page-header-icon {
    width: 44px;
    height: 44px;
    background: rgba(255, 255, 255, 0.12);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
  }

  .page-header-title {
    font-family: 'Outfit', sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: white;
  }

  .page-header-sub {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.6);
    margin-top: 2px;
  }

  .page-header-logo {
    height: 52px;
    opacity: 0.9;
  }

  .page-body {
    padding: 44px 52px;
    flex: 1;
  }

  .page-body-compact {
    padding: 20px 52px 24px;
    flex: 1;
  }

  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: linear-gradient(90deg, #e0f7fa, #e8f5e9);
    border-left: 4px solid var(--teal);
    padding: 6px 16px;
    border-radius: 0 8px 8px 0;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 10px;
  }

  .section-heading {
    font-family: 'Outfit', sans-serif;
    font-size: 28px;
    font-weight: 800;
    color: var(--navy);
    line-height: 1.2;
    margin-bottom: 8px;
  }

  .section-heading span {
    color: var(--pink);
  }

  .section-intro {
    font-size: 14px;
    color: var(--gray);
    line-height: 1.7;
    margin-bottom: 32px;
    max-width: 620px;
  }

  /* ─── STAT BOXES ─── */
  .stat-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 16px;
  }

  .stat-box {
    background: linear-gradient(135deg, var(--light) 0%, white 100%);
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 12px 14px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .stat-box::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--teal), var(--pink));
  }

  .stat-number {
    font-family: 'Outfit', sans-serif;
    font-size: 38px;
    font-weight: 800;
    background: linear-gradient(135deg, var(--navy), var(--teal));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
    margin-bottom: 6px;
  }

  .stat-label {
    font-size: 12px;
    color: var(--gray);
    font-weight: 500;
    line-height: 1.4;
  }

  /* ─── INFO CARD ─── */
  .info-card {
    background: linear-gradient(135deg, #fff8ff 0%, #f0fafc 100%);
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 14px 20px;
    margin-bottom: 12px;
  }

  .info-card-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
  }

  .info-card-icon {
    font-size: 26px;
  }

  .info-card-title {
    font-family: 'Outfit', sans-serif;
    font-size: 17px;
    font-weight: 700;
    color: var(--navy);
  }

  .info-card-body {
    font-size: 13.5px;
    color: #374151;
    line-height: 1.75;
  }

  /* ─── ROADMAP STEPS ─── */
  .roadmap {
    position: relative;
    padding-left: 32px;
  }

  .roadmap::before {
    content: '';
    position: absolute;
    left: 15px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--teal), var(--pink));
  }

  .roadmap-step {
    position: relative;
    margin-bottom: 28px;
    background: white;
    border: 1px solid #e8f0fe;
    border-radius: 14px;
    padding: 20px 22px 20px 52px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
  }

  .roadmap-step::before {
    content: attr(data-num);
    position: absolute;
    left: -18px;
    top: 50%;
    transform: translateY(-50%);
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--teal), var(--navy));
    color: white;
    font-size: 13px;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .step-phase {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 4px;
  }

  .step-title {
    font-family: 'Outfit', sans-serif;
    font-size: 16px;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 6px;
  }

  .step-desc {
    font-size: 13px;
    color: var(--gray);
    line-height: 1.6;
  }

  .step-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 10px;
  }

  .tag {
    background: #e0f7fa;
    color: #00838f;
    font-size: 11px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 100px;
  }

  .tag.pink {
    background: #fce4ec;
    color: #c2185b;
  }

  .tag.navy {
    background: #e8eaf6;
    color: #283593;
  }

  .tag.green {
    background: #e8f5e9;
    color: #2e7d32;
  }

  /* ─── SKILL GRID ─── */
  .skill-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 24px;
  }

  .skill-card {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    padding: 18px 20px;
    position: relative;
    overflow: hidden;
  }

  .skill-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 4px;
  }

  .skill-card.teal::before {
    background: linear-gradient(to bottom, var(--teal), var(--teal2));
  }

  .skill-card.pink::before {
    background: linear-gradient(to bottom, var(--pink), var(--pink2));
  }

  .skill-card.navy::before {
    background: linear-gradient(to bottom, var(--navy), #3949ab);
  }

  .skill-card.green::before {
    background: linear-gradient(to bottom, var(--green), #81c784);
  }

  .skill-emoji {
    font-size: 22px;
    margin-bottom: 8px;
    display: block;
  }

  .skill-name {
    font-weight: 700;
    font-size: 14px;
    color: var(--navy);
    margin-bottom: 6px;
  }

  .skill-list {
    list-style: none;
    font-size: 12.5px;
    color: var(--gray);
    line-height: 1.8;
  }

  .skill-list li::before {
    content: '→ ';
    color: var(--teal);
    font-weight: 700;
  }

  /* ─── CAREER PATHS ─── */
  .career-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    margin-bottom: 28px;
  }

  .career-card {
    border-radius: 14px;
    padding: 20px 16px;
    text-align: center;
  }

  .career-card.c1 {
    background: linear-gradient(135deg, #e0f7fa, #b2ebf2);
  }

  .career-card.c2 {
    background: linear-gradient(135deg, #fce4ec, #f8bbd0);
  }

  .career-card.c3 {
    background: linear-gradient(135deg, #e8eaf6, #c5cae9);
  }

  .career-card.c4 {
    background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
  }

  .career-card.c5 {
    background: linear-gradient(135deg, #fff3e0, #ffe0b2);
  }

  .career-card.c6 {
    background: linear-gradient(135deg, #f3e5f5, #e1bee7);
  }

  .career-icon {
    font-size: 28px;
    margin-bottom: 8px;
    display: block;
  }

  .career-title {
    font-weight: 700;
    font-size: 13px;
    color: var(--navy);
    margin-bottom: 4px;
  }

  .career-pay {
    font-size: 12px;
    font-weight: 600;
    color: var(--teal);
  }

  /* ─── HIGHLIGHT BOX ─── */
  .highlight-box {
    background: linear-gradient(135deg, var(--navy) 0%, #1e3a8a 100%);
    border-radius: 18px;
    padding: 28px 32px;
    margin: 24px 0;
    position: relative;
    overflow: hidden;
  }

  .highlight-box::before {
    content: '';
    position: absolute;
    top: -60px;
    right: -60px;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    background: rgba(0, 188, 212, 0.15);
  }

  .highlight-box h3 {
    font-family: 'Outfit', sans-serif;
    font-size: 20px;
    font-weight: 700;
    color: white;
    margin-bottom: 14px;
    position: relative;
  }

  .highlight-box p {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.7;
    position: relative;
  }

  .highlight-box .quote-mark {
    font-size: 60px;
    color: rgba(0, 188, 212, 0.3);
    font-family: serif;
    line-height: 1;
    position: absolute;
    top: 16px;
    right: 32px;
  }

  /* ─── TOOL LIST ─── */
  .tool-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-bottom: 24px;
  }

  .tool-card {
    background: var(--gray-lt);
    border-radius: 12px;
    padding: 14px 12px;
    text-align: center;
    border: 1px solid #e2e8f0;
  }

  .tool-icon {
    font-size: 24px;
    margin-bottom: 6px;
    display: block;
  }

  .tool-name {
    font-size: 12px;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 3px;
  }

  .tool-use {
    font-size: 11px;
    color: var(--gray);
  }

  /* ─── MYTHS ─── */
  .myth-row {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 12px;
  }

  .myth-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid #e2e8f0;
  }

  .myth-left {
    background: #fff5f5;
    padding: 8px 12px;
    border-right: 2px dashed #fca5a5;
  }

  .myth-right {
    background: #f0fdf4;
    padding: 8px 12px;
  }

  .myth-label {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 6px;
  }

  .myth-left .myth-label {
    color: #dc2626;
  }

  .myth-right .myth-label {
    color: #16a34a;
  }

  .myth-text {
    font-size: 13px;
    line-height: 1.5;
    color: #374151;
    font-weight: 500;
  }

  /* ─── CTA PAGE ─── */
  .cta-page {
    height: 100%;
    background: linear-gradient(145deg, var(--dark) 0%, var(--navy) 55%, #1e3a8a 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 60px;
    position: relative;
    overflow: hidden;
  }

  .cta-page::before {
    content: '';
    position: absolute;
    top: -150px;
    right: -150px;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(0, 188, 212, 0.2) 0%, transparent 60%);
  }

  .cta-page::after {
    content: '';
    position: absolute;
    bottom: -100px;
    left: -100px;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(233, 30, 140, 0.18) 0%, transparent 60%);
  }

  .cta-logo {
    height: 120px;
    margin-bottom: 36px;
    z-index: 2;
  }

  .cta-label {
    background: rgba(0, 188, 212, 0.2);
    border: 1px solid rgba(0, 188, 212, 0.4);
    color: var(--teal2);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    padding: 6px 20px;
    border-radius: 100px;
    margin-bottom: 24px;
    z-index: 2;
  }

  .cta-title {
    font-family: 'Outfit', sans-serif;
    font-size: 42px;
    font-weight: 800;
    color: white;
    text-align: center;
    line-height: 1.2;
    margin-bottom: 16px;
    z-index: 2;
  }

  .cta-title span {
    background: linear-gradient(90deg, var(--teal2), var(--pink2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .cta-desc {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.7);
    text-align: center;
    max-width: 500px;
    line-height: 1.7;
    margin-bottom: 48px;
    z-index: 2;
  }

  .cta-steps {
    display: flex;
    flex-direction: column;
    gap: 16px;
    width: 100%;
    max-width: 560px;
    margin-bottom: 48px;
    z-index: 2;
  }

  .cta-step {
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 14px;
    padding: 18px 24px;
    display: flex;
    align-items: center;
    gap: 18px;
  }

  .cta-step-num {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--teal), var(--navy));
    color: white;
    font-size: 15px;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .cta-step-text strong {
    display: block;
    color: white;
    font-size: 14px;
    font-weight: 700;
    margin-bottom: 2px;
  }

  .cta-step-text span {
    color: rgba(255, 255, 255, 0.6);
    font-size: 13px;
  }

  .cta-divider {
    width: 60px;
    height: 2px;
    background: linear-gradient(90deg, var(--teal), var(--pink));
    border-radius: 2px;
    margin: 36px 0;
    z-index: 2;
  }

  .cta-footer-text {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.45);
    text-align: center;
    z-index: 2;
  }

  .cta-footer-text strong {
    color: var(--teal2);
  }

  /* ─── PAGE FOOTER BAR ─── */
  .page-footer {
    background: #f8fafc;
    border-top: 1px solid #e2e8f0;
    padding: 12px 52px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .page-footer-brand {
    font-size: 11px;
    font-weight: 700;
    color: var(--teal);
    letter-spacing: 1px;
  }

  .page-footer-page {
    font-size: 11px;
    color: var(--gray);
  }

  /* ─── CHECKLIST ─── */
  .checklist {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .checklist li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 13.5px;
    color: #374151;
    line-height: 1.6;
    padding: 10px 14px;
    background: var(--gray-lt);
    border-radius: 10px;
  }

  .check-icon {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 1px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 800;
    color: white;
  }

  .check-icon.teal {
    background: linear-gradient(135deg, var(--teal), var(--teal2));
  }

  .check-icon.pink {
    background: linear-gradient(135deg, var(--pink), var(--pink2));
  }

  .check-icon.navy {
    background: linear-gradient(135deg, var(--navy), #3949ab);
  }

  /* print */
  @media print {
    @page {
      size: A4;
      margin: 0;
    }

    body {
      background: white;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    .page {
      margin: 0 auto;
      box-shadow: none;
      page-break-inside: avoid;
