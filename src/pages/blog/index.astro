---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
};
---

<Layout 
  title="Moleculytics Blog – AI in Pharma, Cheminformatics & Drug Discovery"
  description="Stay updated with the latest in molecular machine learning, computational chemistry tutorials, and career opportunities in India."
>
  <main class="blog-container">
    <header class="blog-header-section">
      <div class="container">
        <span class="section-label">Resources & Insights</span>
        <h1 class="blog-title-main">The Moleculytics <span>Blog</span></h1>
        <p class="blog-desc-main">
          Practical tutorials, industry analysis, and step-by-step guides helping life scientists bridge the gap to artificial intelligence.
        </p>
      </div>
    </header>

    <section class="posts-section">
      <div class="container">
        {posts.length === 0 ? (
          <div class="empty-state">
            <p>No blog posts published yet. Stay tuned!</p>
          </div>
        ) : (
          <div class="posts-grid">
            {posts.map((post) => (
              <article class="post-card">
                <div class="post-meta">
                  <span class="post-date">{formatDate(post.data.pubDate)}</span>
                  <span class="post-author">By {post.data.author}</span>
                </div>
                <h2 class="post-title">
                  <a href={`/blog/${post.slug}`}>{post.data.title}</a>
                </h2>
                <p class="post-excerpt">{post.data.description}</p>
                <div class="post-footer-link">
                  <a href={`/blog/${post.slug}`} class="read-more-btn">
                    Read Article <span>→</span>
                  </a>
                </div>
              </article>
            ))}
          </div>
        )}
      </div>
    </section>
  </main>
</Layout>

<style>
  .blog-container {
    padding-top: 140px;
    padding-bottom: 80px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .blog-header-section {
    padding: 60px 0 40px;
    text-align: center;
    position: relative;
  }

  /* background glow */
  .blog-header-section::before {
    content: '';
    position: absolute;
    top: -50px;
    left: 50%;
    transform: translateX(-50%);
    width: 500px;
    height: 300px;
    background: radial-gradient(circle, rgba(0, 188, 212, 0.1) 0%, transparent 70%);
    z-index: -1;
    pointer-events: none;
  }

  .section-label {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 16px;
  }

  .blog-title-main {
    font-size: 48px;
    line-height: 1.1;
    margin-bottom: 20px;
    letter-spacing: -1px;
  }

  .blog-title-main span {
    background: linear-gradient(90deg, var(--teal), var(--pink));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .blog-desc-main {
    font-size: 18px;
    color: var(--gray-text);
    max-width: 650px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .posts-section {
    padding: 40px 0 80px;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: 30px;
    margin-top: 20px;
  }

  .post-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 20px;
    padding: 36px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .post-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: transparent;
    transition: background 0.3s ease;
  }

  .post-card:hover {
    border-color: rgba(0, 188, 212, 0.3);
    transform: translateY(-5px);
    background: rgba(255, 255, 255, 0.05);
  }

  .post-card:hover::before {
    background: linear-gradient(to bottom, var(--teal), var(--pink));
  }

  .post-meta {
    display: flex;
    justify-content: space-between;
    font-size: 12px;
    color: var(--gray-text);
    font-weight: 500;
    margin-bottom: 16px;
  }

  .post-date {
    color: var(--teal);
  }

  .post-title {
    font-size: 22px;
    line-height: 1.3;
    margin-bottom: 14px;
    font-weight: 700;
  }

  .post-title a {
    color: var(--white);
  }

  .post-title a:hover {
    color: var(--teal);
  }

  .post-excerpt {
    color: var(--gray-text);
    font-size: 14.5px;
    line-height: 1.6;
    margin-bottom: 24px;
    flex-grow: 1;
  }

  .post-footer-link {
    margin-top: auto;
  }

  .read-more-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13.5px;
    font-weight: 700;
    color: var(--teal);
    transition: all 0.3s ease;
  }

  .read-more-btn span {
    transition: transform 0.3s ease;
  }

  .read-more-btn:hover {
    color: var(--pink);
  }

  .read-more-btn:hover span {
    transform: translateX(4px);
  }

  .empty-state {
    text-align: center;
    padding: 80px 20px;
    background: var(--card-bg);
    border: 1px dashed var(--card-border);
    border-radius: 20px;
    color: var(--gray-text);
  }

  @media (max-width: 768px) {
    .blog-container {
      padding-top: 110px;
    }
    .blog-title-main {
      font-size: 36px;
    }
    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
