---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

const post = Astro.props;
const { Content } = await post.render();

const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};
---

<Layout title={`${post.data.title} – Moleculytics`} description={post.data.description}>
  <main class="post-container">
    <div class="container">
      <div class="back-link-wrap">
        <a href="/blog" class="back-to-blog-btn">
          <span>←</span> Back to Blog
        </a>
      </div>

      <article class="blog-post">
        <header class="post-header">
          <div class="post-header-meta">
            <span class="post-date">{formatDate(post.data.pubDate)}</span>
            <span class="post-separator">•</span>
            <span class="post-author">Published by {post.data.author}</span>
          </div>
          <h1 class="post-title-heading">{post.data.title}</h1>
          <p class="post-description-intro">{post.data.description}</p>
          <div class="post-header-divider"></div>
        </header>

        <div class="blog-post-content">
          <Content />
        </div>
      </article>
    </div>
  </main>
</Layout>

<style is:global>
  /* Styling classes targeting rendered Markdown tags inside .blog-post-content */
  .blog-post-content p {
    font-size: 16.5px;
    line-height: 1.8;
    color: #cbd5e1;
    margin-bottom: 24px;
  }

  .blog-post-content p strong {
    color: var(--white);
    font-weight: 600;
  }

  .blog-post-content h2 {
    font-family: 'Outfit', sans-serif;
    font-size: 26px;
    color: var(--white);
    margin: 48px 0 16px;
    font-weight: 700;
    line-height: 1.3;
    background: linear-gradient(90deg, var(--white), var(--teal));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .blog-post-content h3 {
    font-family: 'Outfit', sans-serif;
    font-size: 20px;
    color: var(--white);
    margin: 36px 0 12px;
    font-weight: 600;
  }

  .blog-post-content ul, .blog-post-content ol {
    margin-bottom: 24px;
    padding-left: 24px;
  }

  .blog-post-content li {
    font-size: 16px;
    color: #cbd5e1;
    line-height: 1.7;
    margin-bottom: 10px;
  }

  .blog-post-content li strong {
    color: var(--white);
  }

  .blog-post-content hr {
    border: 0;
    border-top: 1px solid var(--card-border);
    margin: 48px 0;
  }

  .blog-post-content blockquote {
    border-left: 4px solid var(--teal);
    background: rgba(0, 188, 212, 0.05);
    padding: 16px 24px;
    margin: 24px 0;
    border-radius: 0 12px 12px 0;
    font-style: italic;
  }

  .blog-post-content blockquote p {
    margin-bottom: 0;
    color: var(--white);
  }

  /* Pre & code styling for syntax highlighting in Markdown */
  .blog-post-content pre {
    background: rgba(26, 43, 107, 0.3) !important;
    border: 1px solid var(--card-border);
    border-radius: 12px;
    padding: 20px !important;
    margin-bottom: 28px;
    overflow-x: auto;
    font-family: monospace;
    font-size: 14px;
  }

  .blog-post-content code {
    font-family: monospace;
    background: rgba(255, 255, 255, 0.05);
    padding: 3px 6px;
    border-radius: 4px;
    font-size: 14px;
    color: var(--teal);
  }

  .blog-post-content pre code {
    background: transparent;
    padding: 0;
    border-radius: 0;
    color: inherit;
    font-size: inherit;
  }
</style>

<style>
  .post-container {
    padding-top: 140px;
    padding-bottom: 100px;
    flex: 1;
  }

  .back-link-wrap {
    margin-bottom: 30px;
  }

  .back-to-blog-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 700;
    color: var(--gray-text);
    transition: all 0.3s ease;
  }

  .back-to-blog-btn span {
    transition: transform 0.3s ease;
  }

  .back-to-blog-btn:hover {
    color: var(--teal);
  }

  .back-to-blog-btn:hover span {
    transform: translateX(-4px);
  }

  .blog-post {
    max-width: 800px;
    margin: 0 auto;
    background: linear-gradient(135deg, rgba(26, 43, 107, 0.2) 0%, rgba(13, 27, 75, 0.4) 100%);
    border: 1px solid var(--card-border);
    border-radius: 24px;
    padding: 50px;
    backdrop-filter: blur(10px);
  }

  .post-header {
    margin-bottom: 36px;
  }

  .post-header-meta {
    font-size: 13.5px;
    font-weight: 500;
    color: var(--gray-text);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .post-date {
    color: var(--teal);
  }

  .post-title-heading {
    font-size: 40px;
    line-height: 1.2;
    margin-bottom: 18px;
    letter-spacing: -0.5px;
  }

  .post-description-intro {
    font-size: 18px;
    color: var(--gray-text);
    line-height: 1.6;
    margin-bottom: 28px;
  }

  .post-header-divider {
    height: 1px;
    background: linear-gradient(90deg, var(--card-border) 0%, rgba(255, 255, 255, 0.02) 100%);
  }

  @media (max-width: 768px) {
    .post-container {
      padding-top: 110px;
    }
    .blog-post {
      padding: 30px 20px;
      border-radius: 16px;
    }
    .post-title-heading {
      font-size: 28px;
    }
    .post-description-intro {
      font-size: 15px;
    }
  }
</style>
