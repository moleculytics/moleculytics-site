---
interface Props {
  title?: string;
  description?: string;
  showHeader?: boolean;
  showFooter?: boolean;
}

const { 
  title = "Moleculytics – AI Education for Pharma & Life Science Graduates", 
  description = "Enter the world of AI-powered drug discovery. Learn Python, Cheminformatics, and Molecular ML designed specifically for life scientists in India.",
  showHeader = true,
  showFooter = true
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  
  <!-- Analytics -->
  <script defer src="https://cloud.umami.is/script.js" data-website-id="168d2b45-f4bf-419b-9807-d8af50ab9171"></script>
  
  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Outfit:wght@300;400;600;700;800;900&display=swap" rel="stylesheet" />
  
  <style is:global>
    /* ─── RESET & VARIABLES ─── */
    *,
    *::before,
    *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --navy-dark: #0D1B4B;
      --navy: #1A2B6B;
      --navy-light: #1E3A8A;
      --teal: #00BCD4;
      --teal-dark: #0097A7;
      --pink: #FF4DB8;
      --pink-dark: #E91E8C;
      --white: #FFFFFF;
      --gray-light: #F8FAFC;
      --gray-text: #94A3B8;
      --body-text: #E2E8F0;
      --card-bg: rgba(255, 255, 255, 0.03);
      --card-border: rgba(255, 255, 255, 0.08);
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Inter', sans-serif;
      background-color: var(--navy-dark);
      color: var(--body-text);
      line-height: 1.6;
      overflow-x: hidden;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }

    h1, h2, h3, h4 {
      font-family: 'Outfit', sans-serif;
      font-weight: 700;
      color: var(--white);
    }

    a {
      text-decoration: none;
      color: inherit;
      transition: all 0.3s ease;
    }

    .container {
      width: 100%;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
    }
  </style>

  <style>
    /* ─── HEADER & NAV ─── */
    header {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      z-index: 1000;
      background: rgba(13, 27, 75, 0.8);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--card-border);
      padding: 16px 0;
    }

    .nav-wrapper {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .logo img {
      height: 48px;
    }

    .logo-text {
      font-family: 'Outfit', sans-serif;
      font-size: 22px;
      font-weight: 800;
      letter-spacing: 1px;
      color: var(--white);
    }

    .logo-text span {
      color: var(--teal);
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 32px;
    }

    .nav-link {
      font-size: 14px;
      font-weight: 500;
      color: var(--gray-text);
    }

    .nav-link:hover {
      color: var(--teal);
    }

    .btn-nav {
      background: rgba(0, 188, 212, 0.15);
      border: 1px solid var(--teal);
      color: var(--teal);
      padding: 8px 18px;
      border-radius: 100px;
      font-size: 13px;
      font-weight: 600;
    }

    .btn-nav:hover {
      background: var(--teal);
      color: var(--navy-dark);
      box-shadow: 0 0 20px rgba(0, 188, 212, 0.4);
    }

    /* Mobile menu hamburger toggle */
    .menu-toggle {
      display: none;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
    }

    .menu-toggle span {
      width: 25px;
      height: 3px;
      background-color: var(--white);
      border-radius: 2px;
      transition: all 0.3s ease;
    }

    /* ─── FOOTER ─── */
    footer {
      border-top: 1px solid var(--card-border);
      background: rgba(9, 19, 52, 0.5);
      padding: 60px 0 40px;
      margin-top: auto;
    }

    .footer-grid {
      display: grid;
      grid-template-columns: 1.5fr 1fr;
      gap: 60px;
      margin-bottom: 40px;
    }

    .footer-brand p {
      font-size: 14px;
      color: var(--gray-text);
      margin-top: 12px;
      max-width: 400px;
    }

    .footer-links {
      display: flex;
      justify-content: flex-end;
      gap: 60px;
    }

    .footer-col h4 {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: var(--teal);
      margin-bottom: 20px;
    }

    .footer-col ul {
      list-style: none;
    }

    .footer-col ul li {
      margin-bottom: 12px;
      font-size: 13.5px;
    }

    .footer-col ul li a {
      color: var(--gray-text);
    }

    .footer-col ul li a:hover {
      color: var(--white);
    }

    .footer-bottom {
      border-top: 1px solid rgba(255, 255, 255, 0.05);
      padding-top: 30px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 12.5px;
      color: var(--gray-text);
    }

    .footer-bottom a {
      color: var(--teal);
    }

    /* ─── RESPONSIVE STYLES ─── */
    @media (max-width: 768px) {
      .nav-links {
        display: none;
      }
      .menu-toggle {
        display: flex;
      }
      
      /* Mobile Menu Toggle Class */
      .nav-links.active {
        display: flex;
        flex-direction: column;
        position: absolute;
        top: 80px;
        left: 0;
        width: 100%;
        background-color: var(--navy-dark);
        border-bottom: 1px solid var(--card-border);
        padding: 30px 24px;
        gap: 20px;
        align-items: stretch;
      }
      .nav-links.active .btn-nav {
        text-align: center;
      }

      .footer-grid {
        grid-template-columns: 1fr;
        gap: 40px;
      }
      .footer-links {
        justify-content: flex-start;
      }
      .footer-bottom {
        flex-direction: column;
        gap: 15px;
        text-align: center;
      }
    }
  </style>
</head>
<body>

  <!-- ─── HEADER & NAVIGATION ─── -->
  {showHeader && (
    <header>
      <div class="container nav-wrapper">
        <a href="/" class="logo">
          <img src="/Moleculytics My brand.png" alt="Moleculytics Logo" />
          <span class="logo-text">Moleculytics<span>.in</span></span>
        </a>
        
        <div class="menu-toggle" id="mobile-menu-btn">
          <span></span>
          <span></span>
          <span></span>
        </div>

        <nav class="nav-links" id="nav-menu">
          <a href="/#workshops" class="nav-link">Workshops</a>
          <a href="/#about" class="nav-link">Why AI?</a>
          <a href="/#roadmap" class="nav-link">Free Roadmap</a>
          <a href="/blog" class="nav-link">Blog</a>
          <a href="mailto:hello@moleculytics.in" class="nav-link">Contact</a>
          <a href="https://forms.gle/ZGMrf2sWeRbbn6Mg8" target="_blank" rel="noopener" class="btn-nav">Join Next Workshop</a>
        </nav>
      </div>
    </header>
  )}

  <slot />

  <!-- ─── FOOTER ─── -->
  {showFooter && (
    <footer>
      <div class="container">
        <div class="footer-grid">
          <div class="footer-brand">
            <a href="/" class="logo">
              <img src="/Moleculytics My brand.png" alt="Moleculytics Logo" />
              <span class="logo-text">Moleculytics<span>.in</span></span>
            </a>
            <p>
              Bridging the gap between molecular biology and artificial intelligence. Dedicated AI education for pharmaceutical scientists, professionals, and students in India.
            </p>
          </div>
          <div class="footer-links">
            <div class="footer-col">
              <h4>Education</h4>
              <ul>
                <li><a href="/#workshops">Workshops</a></li>
                <li><a href="/#roadmap">Free Roadmap</a></li>
                <li><a href="https://forms.gle/ZGMrf2sWeRbbn6Mg8" target="_blank" rel="noopener">Interest Form</a></li>
              </ul>
            </div>
            <div class="footer-col">
              <h4>Company</h4>
              <ul>
                <li><a href="mailto:hello@moleculytics.in">hello@moleculytics.in</a></li>
                <li><a href="https://www.linkedin.com/company/moleculytics/" target="_blank" rel="noopener">LinkedIn Page</a></li>
                <li><a href="/privacy-policy">Privacy Policy</a></li>
              </ul>
            </div>
          </div>
        </div>
        <div class="footer-bottom">
          <p>© 2026 Moleculytics. All rights reserved. Created in India.</p>
          <p><a href="/privacy-policy">Privacy Policy</a></p>
        </div>
      </div>
    </footer>
  )}

  <!-- ─── MOBILE MENU TOGGLE SCRIPT ─── -->
  <script>
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const navMenu = document.getElementById('nav-menu');

    if (mobileMenuBtn && navMenu) {
      mobileMenuBtn.addEventListener('click', () => {
        navMenu.classList.toggle('active');
        mobileMenuBtn.querySelectorAll('span').forEach((bar, index) => {
          if (navMenu.classList.contains('active')) {
            if (index === 0) bar.style.transform = 'rotate(45deg) translate(6px, 6px)';
            if (index === 1) bar.style.opacity = '0';
            if (index === 2) bar.style.transform = 'rotate(-45deg) translate(5px, -5px)';
          } else {
            bar.style.transform = 'none';
            bar.style.opacity = '1';
          }
        });
      });

      // Close mobile menu when a nav link is clicked
      document.querySelectorAll('.nav-link, .btn-nav').forEach(link => {
        link.addEventListener('click', () => {
          navMenu.classList.remove('active');
          mobileMenuBtn.querySelectorAll('span').forEach(bar => {
            bar.style.transform = 'none';
            bar.style.opacity = '1';
          });
        });
      });
    }
  </script>
</body>
</html>
